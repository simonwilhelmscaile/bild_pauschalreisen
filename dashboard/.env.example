# Supabase credentials (server-side only, never sent to browser)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Dashboard access password (leave empty to disable auth)
DASHBOARD_PASSWORD=

# Scaile admin password for content approval (separate from DASHBOARD_PASSWORD)
ADMIN_PASSWORD=

# Gemini API key for article generation/regeneration/inline edits
GEMINI_API_KEY=your-gemini-api-key

# Optional: Gemini model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Optional: Python backend URL for full blog pipeline (stages 2-5)
# If set, article generation proxies to the Python backend instead of using the TS generator
# BACKEND_URL=http://localhost:8000

# Optional: Peekaboo API key for AI visibility analytics tab
# Get from https://www.aipeekaboo.com
PEEKABOO_API_KEY=
