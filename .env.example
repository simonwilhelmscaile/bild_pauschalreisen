# Social Listening Service - Environment Variables
# Copy this file to .env and fill in your values

# Supabase - Database + Auth (Beurer project)
BEURER_SUPABASE_URL=https://xxxxx.supabase.co
BEURER_SUPABASE_KEY=your-supabase-service-role-key

# Firecrawl - Web Scraping (gutefrage, health forums)
# Get from https://firecrawl.dev
FIRECRAWL_API_KEY=fc-xxxxx

# Apify - Platform scrapers (Amazon, Reddit, YouTube, TikTok, Instagram)
# Get from https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_xxxxx

# Gemini - Classification + Embeddings
# Get from https://aistudio.google.com
GEMINI_API_KEY=AIza-xxxxx

# Optional: Serper - Google Search API (for source discovery)
# Get from https://serper.dev
SERPER_API_KEY=xxxxx
